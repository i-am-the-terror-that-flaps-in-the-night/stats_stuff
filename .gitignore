# ---- Python ----
__pycache__/
*.py[cod]
*$py.class
*.so

# Packaging / build
build/
dist/
sdist/
wheels/
*.egg
*.egg-info/
.eggs/
*.whl
*.tar.gz

# ---- Virtual environments ----
.venv/
venv/
env/
ENV/

# ---- uv ----
# uv.lock is intentionally committed; only the cache is ignored.
.uv/
.uv-cache/

# ---- Testing / type checking / linting ----
.pytest_cache/
.ruff_cache/
.mypy_cache/
.dmypy.json
.pyre/
.pytype/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/

# ---- Jupyter ----
.ipynb_checkpoints/
*-checkpoint.ipynb
profile_default/
ipython_config.py
*.ipynb

# ---- Generated output ----
# Figures are generated artifacts (no current script reproduces them).
# Delete the lines below if you want to version specific figures.
figures/
*.pdf
*.png
*.jpg
*.svg

# ---- Data artifacts (keep source Data/data.csv tracked, ignore scratch) ----
*.parquet
*.feather
*.pkl
*.h5
*.hdf5
*.csv
# ...but keep the small practice dataset tracked.
!Data/data.csv

# ---- Django ----
# Local run log. The host has no persistent disk, so this is never shared state.
# Committing it would bake a stale database into the deployed image.
*.sqlite3
*.sqlite3-journal
*.sqlite3-wal
*.sqlite3-shm

# ---- Environment / secrets ----
.env
.env.*
!.env.example

# ---- Security scan output (nuclei etc. -- don't broadcast findings) ----
nuclei*
*.nuclei
.nuclei/
.nuclei-templates/

# ---- IDE / editors ----
.idea/
*.iml
*.iws
*.ipr
.vscode/
*.code-workspace
*.swp
*.swo
*~
.claude

# ---- OS ----
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
ehthumbs.db
Desktop.ini

# Studio run-log (local lab notebook; free tier has no persistent disk)
Backend/studio_runs.db
